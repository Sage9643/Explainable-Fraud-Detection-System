# Copy this file to .env and adjust as needed for your environment.
# Every value here is read through utils/config.py - never hardcode these
# elsewhere in the codebase.

# --- App ---
APP_NAME=FraudLens AI
APP_ENV=development
LOG_LEVEL=INFO

# --- Model artifacts ---
# Directory containing model.json, scaler.pkl, metadata.json, feature_columns.json
MODEL_ARTIFACTS_DIR=models/artifacts
MODEL_FILENAME=model.json
SCALER_FILENAME=scaler.pkl
METADATA_FILENAME=metadata.json
FEATURE_COLUMNS_FILENAME=feature_columns.json

# --- Database ---
DATABASE_URL=sqlite:///./fraudlens.db

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# --- Batch prediction ---
MAX_BATCH_ROWS=50000000
MAX_UPLOAD_SIZE_MB=1400
BATCH_OUTPUT_DIR=generated/batch_results